# Copy to .env and fill in from Supabase → Project Settings → API
# For Google sign-in: Supabase → Authentication → Providers → Google (OAuth client from Google Cloud Console)
# Add redirect URLs under Authentication → URL Configuration (e.g. http://localhost:5173/ and your production URL)

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# PostHog (optional) — free tier at https://posthog.com
# Project → Settings → Project API Key
VITE_POSTHOG_KEY=
# Leave empty for US cloud, or set https://eu.i.posthog.com for EU hosting
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Paddle Billing — sandbox checkout for “Claim a founding seat”
# Dashboard: https://sandbox-vendors.paddle.com (or Production when live)
# 1) Developer tools → Authentication → create a client-side token
# 2) Catalog → create a product + price → copy Price ID (pri_...)
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_PRICE_ID=
# Optional: defaults to sandbox. Use production only with live keys + live price ID.
# VITE_PADDLE_ENV=sandbox

# Contact form (optional) — https://web3forms.com — free tier, access key is safe in frontend
# Create a form and set the notification email to info@ryft.us (or your support inbox)
# Without this, “Send message” opens the visitor’s mail app with a prefilled email instead.
VITE_WEB3FORMS_ACCESS_KEY=
